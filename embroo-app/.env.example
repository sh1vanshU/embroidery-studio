# ─── Application ────────────────────────────────────────────────────────────
# Public URL used for CORS, OAuth callbacks, and absolute links.
NEXT_PUBLIC_APP_URL="https://embroo.in"

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
# For Neon: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# For local: postgresql://postgres:postgres@localhost:5432/embroo
DATABASE_URL=""

# Optional shadow DB used by `prisma migrate dev` (Neon: same project, different branch)
SHADOW_DATABASE_URL=""

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# In production must match deployed URL; in dev http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional — provider only enabled if both are set) ──────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Razorpay (Payments) ───────────────────────────────────────────────────
# Test keys: rzp_test_*** | Live keys: rzp_live_***
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ─── Cloudinary (Image hosting) ────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Resend (Transactional Email) ──────────────────────────────────────────
# Optional — newsletter/help endpoints fall back to logging when absent.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Embroo India <hello@embroo.in>"
RESEND_TO_SUPPORT="support@embroo.in"

# ─── Misc ──────────────────────────────────────────────────────────────────
# Set to 1 to allow CORS from any origin in non-production environments.
ALLOW_DEV_CORS=""
